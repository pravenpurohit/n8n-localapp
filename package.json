  },
  "dependencies": {
    "@sveltejs/kit": "^2.21.1",
    "@tauri-apps/api": "^2.5.0",
    "@xyflow/svelte": "^1.5.0",
    "prismjs": "^1.30.0",
    "svelte": "^5.34.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/prismjs": "^1.26.5",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.4.0",
    "fast-check": "^4.1.1",
    "jsdom": "^29.0.1",
    "svelte-check": "^4.2.1",
