# LLM Provider API Keys for Test Workflows
#
# IMPORTANT: These keys serve TWO purposes:
# 1. Reference — so you know which keys are needed
# 2. n8n credential creation — the scripts/create-llm-test-workflows.ts
#    script reads these to create credentials in n8n via the API
#
# The ACTUAL keys used by workflows at runtime are stored in n8n's
# credential store (managed via n8n UI or API), NOT read from this file.
# If you change a key here, re-run: npx tsx scripts/create-llm-test-workflows.ts

# OpenAI (used by W1/W2 originals — gpt-4o)
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (used by W1/W2 Gemini variants — gemini-1.5-pro)
GOOGLE_AI_API_KEY=your-google-ai-key-here

# Anthropic Claude (used by W1/W2 Claude variants — claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Groq (used by W1/W2 Groq variants — llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_your-groq-key-here
